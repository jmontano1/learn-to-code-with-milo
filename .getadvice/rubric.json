{
  "version": "1.1.0",
  "$comment": "GetAdvice student-mode rubric, consumed by the getadvice-cloudflare Worker's compute pipeline. Progress is computed ONLY from evidence in the student's own repo (plus feedback notes in this repo), attributed by immutable GitHub numeric user id — never author name. Milestones derive from roadmap.md's stage tables. Evidence vocabulary (worker-defined): file_glob{glob,min_matches} — files matching glob exist in the student repo tree; content_regex{glob,pattern,flags,min_matches} — a matching file's content tests true (first 5 matching files fetched); min_commits{min_commits,distinct_days} — commits authored by the student's numeric id, optionally across N distinct UTC days; feedback_notes{path,min_matches} — files under this repo's feedback-getadvice/notes/; manual — mentor flips it in the roster (reported as pending_mentor until then). Evidence may be an array (all must pass).",
  "stages": [
    {
      "id": "stage-1",
      "name": "Now — first pages",
      "emoji": "🌱",
      "milestones": [
        {
          "id": "first-page",
          "title": "First page on screen",
          "lesson": "lessons/02-your-first-web-page.md",
          "evidence": { "type": "file_glob", "glob": "**/*.html", "min_matches": 1 }
        },
        {
          "id": "styled",
          "title": "It looks good",
          "lesson": "lessons/03-add-style-css.md",
          "evidence": { "type": "content_regex", "glob": "**/*.html", "pattern": "(<style|rel=\"stylesheet\"|\\.css)", "flags": "m" }
        },
        {
          "id": "interactive",
          "title": "It does something",
          "lesson": "lessons/04-make-it-interactive-js.md",
          "evidence": { "type": "content_regex", "glob": "**/*.html", "pattern": "(<script|addEventListener|onclick)", "flags": "m" }
        },
        {
          "id": "own-idea",
          "title": "Your own idea",
          "lesson": "lessons/05-your-own-project.md",
          "evidence": { "type": "file_glob", "glob": "*/index.html", "min_matches": 2 }
        }
      ]
    },
    {
      "id": "stage-2",
      "name": "Next — building bigger, saving like a developer",
      "emoji": "🚀",
      "milestones": [
        {
          "id": "real-save-point",
          "title": "A real save point",
          "lesson": "lessons/06-saving-work-with-git.md",
          "evidence": { "type": "min_commits", "min_commits": 5 }
        },
        {
          "id": "bigger-build",
          "title": "A bigger build",
          "lesson": "lessons/09-a-site-with-rooms.md",
          "evidence": { "type": "file_glob", "glob": "*/*.html", "min_matches": 3 }
        },
        {
          "id": "first-feedback",
          "title": "Your first real feedback",
          "lesson": "lessons/07-giving-good-feedback.md",
          "evidence": { "type": "feedback_notes", "min_matches": 1 }
        },
        {
          "id": "git-habit",
          "title": "The save flow feels normal",
          "lesson": "lessons/06-saving-work-with-git.md",
          "evidence": { "type": "min_commits", "min_commits": 5, "distinct_days": 5 }
        }
      ]
    },
    {
      "id": "stage-3",
      "name": "Later — real work, read strangers' code",
      "emoji": "🌟",
      "milestones": [
        {
          "id": "detective",
          "title": "Bug hunter",
          "lesson": "lessons/13-the-detective-lessons.md",
          "evidence": { "type": "content_regex", "glob": "**/*.md", "pattern": "(bug|fix|debug)", "flags": "im" }
        },
        {
          "id": "capstone",
          "title": "Fix something real",
          "lesson": "lessons/15-capstone-fix-something-real.md",
          "evidence": { "type": "manual" }
        }
      ]
    },
    {
      "id": "stage-4",
      "name": "Ship it to the world",
      "emoji": "🌍",
      "milestones": [
        {
          "id": "audience-of-one",
          "title": "An audience of one",
          "lesson": "lessons/17-deploy-a-marketing-campaign.md",
          "evidence": { "type": "file_glob", "glob": "**/launch/campaign-plan.md", "min_matches": 1 }
        },
        {
          "id": "live-on-internet",
          "title": "Live on the internet",
          "lesson": "lessons/17-deploy-a-marketing-campaign.md",
          "evidence": { "type": "file_glob", "glob": "**/launch/landing/**/*.html", "min_matches": 1 }
        },
        {
          "id": "a-number-you-chose",
          "title": "A number you chose",
          "lesson": "lessons/17-deploy-a-marketing-campaign.md",
          "evidence": { "type": "content_regex", "glob": "**/launch/campaign-plan.md", "pattern": "(target|deadline|metric)", "flags": "im" }
        },
        {
          "id": "told-the-truth",
          "title": "You told the truth",
          "lesson": "lessons/17-deploy-a-marketing-campaign.md",
          "evidence": { "type": "manual" }
        }
      ]
    }
  ]
}
